                    <img src="public/images/payment/visa-logo-png-2026.png" alt="visa, mastercard" width="50%">
                </div>
                <!--Copyright with screen sizes and putting in text-nowrap to keep it all on one line-->
                <div class="col-lg-4 col-12 text-center mb-3 mb-lg-0">
                    <p class="mb-0 text-nowrap">Roberts Footall Shop &copy 2026. All Rights Reserved</p>
                </div>
                <!--Social Media Icons from Font Awesome with links(no links included for this project)-->
                <div class="col-lg-4 col-12 text-lg-end text-center">
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#"><i class="fa-brands fa-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-linkedin-in"></i></i></a>
