        <!-- Premier League -->
        <section id="premierLeague">
            <div class="container text-center mt-5 py-5">
                <h3>Premier League</h3>
                <hr>
            </div>

            <!-- For loop to get info and make 'Cards' for each item-->
            <div class="row">
                <% products.forEach(product=> { %>
                    <!-- Make sure the product is for the correct league -->
                    <% if (product.League==="Premier League" ) { %>
                        <div class="product col-lg-2 col-md-4 col-12 text-center mb-4">
                            <!-- Product Image -->
                            <img src="/public/images/jerseys/<%= product.Image %>" class="img-fluid mb-3">

                            <!-- Product Name and Version (example Arsenal Home)-->
                            <h5>
                                <%= product.Club %>
                                    <%= product.Version %>
                            </h5>

                            <!-- Product Price-->
                            <h4>€<%= product.Price %>
                            </h4>

                            <a href="/shop?rec=<%= product.ID %>">
                                <button class="details">More Details</button>
                            </a>
                        </div>
                        <!-- Close the for and forEach loops-->
                        <% } %>
                            <% }) %>
            </div>
        </section>


