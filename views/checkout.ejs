<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <title>Checkout</title>

    <!--Importing Bootstrap 5 for CSS-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!--Linking CSS file-->
    <link rel="stylesheet" href="/public/css/style.css">

    <!--Font Awesome-->
    <script src="https://kit.fontawesome.com/8875caf3cf.js" crossorigin="anonymous"></script>

    <!-- Favicon Link -->
    <link rel="icon" href="/public/images/favicon/wordmark-favicon.ico" type="image/x-icon">

</head>

<body>
    <!-------------------->
    <!-- Navbar Section -->
    <%- include('templates/navbar') %>

        <!-- End of Navbar Section -->
        <!--------------------------->



        <!-------------------------->
        <!-- Shopping Cart Section-->

        <!-- bootstrap container with top margin of size 5 -->
        <div class="container mt-5">
            <h1 class="checkout-top">Shopping Cart</h1>
            <br>


            <!----------------------->
            <!-- Cart table headers-->
            <!--
                - d-flex = sets the display to flexbox
                - font-weight-bold = makes the font bold
                - border-bottom = adds a border to the bottom to visually separate the header row from the cart items
                - pb-2 = padding-bottom size 2
                - mb-2 = margin-bottom size 2
            -->
            <section>
                <div class="cart-header d-flex font-weight-bold border-bottom pb-2 mb-2">
                    <div class="col-image">Product</div>
                    <div class="col-name"></div>
                    <div class="col-size">Size</div>
                    <div class="col-price">Price</div>
                    <div class="col-quantity">Quantity</div>
                    <div class="col-total">Total</div>
                    <div class="col-cancel">Remove</div>
                </div>
                <!-- End of Cart table headers-->
                <!------------------------------>


                <!--------------------------------------->
                <!-- Items Currently in Cart Container -->
                <!--
                    - items are dynamically inserted by JavaScript (via id of cart_items)
                    - empty_cart is handled by the script if no items in cart
                    - border = adds thin border
                    - p-3 = adds padding of size 3
                    - mb-3 = adds margin-bottom of size 3
                -->
                <div id="cart_items" class="border p-3 mb-3">
                    <p id="empty_cart"></p>
                </div>
                <!-- End of Items Currently in Cart Container -->
                <!---------------------------------------------->


                <!--Final Price for Shopping Cart-->
                <!-- id of final_price used by JavaScript to dynamically insert the final price -->
                <h3 id="final_price" class="text-right"></h3>
                <!-- End of Final Price for Shopping Cart -->
                <!------------------------------------------>

            </section>
            <hr>
            <!-- End of Cart table headers-->
            <!------------------------------>
            



            <!------------------------------------------------>
            <!-- CHECKOUT SECTION -> PAYMENT, NAME, ADDRESS -->
            <!--
                - container for main checkout section
                - mt-5 = margin-top of size 5
                - max-width: 900px = limits the width of the container to 900px
                - mb-4 = ensures the heading Checkout has space below so the form does not sit too close
            
            -->
            <div class="container mt-5" style="max-width: 900px;">
                <h1 class="mb-4">Checkout</h1>


                <!--A Post method for submitting the form, redirects to paymentSuccess page-->
                <form action="/paymentSuccess" method="POST">


                    <!-------------------------------------------->
                    <!-- TOP ROW: Shipping Address (full width) -->
                    <!--
                        - creates a new row
                        - g-3 = adds gap of 3 between columns
                        - mb-4 = adds a margin of size 4 below the row to separate it from the next section 
                    -->
                    <div class="row g-3 mb-4">
                        <!-- col-md-6 = medium screens and larger this takes half the row width, full width on smaller -->
                        <div class="col-md-6">
                            <!--
                                - form-label = bootstrap style and spacing
                                - name="firstName" = key for node.js server known as req.body.firstName
                                - class="form-control" = styling input via bootstrap
                                - required = ensures the form must be filled in before submitting
                            -->
                            <label class="form-label">First Name: </label>
                            <input type="text" name="firstName" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <!-- name="lastName" = key for node.js server known as req.body.lastName -->
                            <label class="form-label">Last Name: </label>
                            <input type="text" name="lastName" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <!-- name="addressLine1" = key for node.js server known as req.body.addressLine1 -->
                            <label class="form-label">Address Line 1: </label>
                            <input type="text" name="addressLine1" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <!-- name="addressLine2" = key for node.js server known as req.body.addressLine2 -->
                            <label class="form-label">Address Line 2: </label>
                            <input type="text" name="addressLine2" class="form-control">
                        </div>

                        <div class="col-md-6">
                            <!-- name="city" = key for node.js server known as req.body.city -->
                            <label class="form-label">City: </label>
                            <input type="text" name="city" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <!-- name="zip" = key for node.js server known as req.body.zip -->
                            <label class="form-label">ZIP / Eircode: </label>
                            <input type="text" name="zip" class="form-control" required>
                        </div>

                        <!-- col-md-12 = column will use full width on all sizes -->
                        <div class="col-md-12">
                            <!-- 
                                - name="email" = key for node.js server known as req.body.email 
                                - type=email = ensures an email address is entered
                            -->
                            <label class="form-label">E-mail: </label>
                            <input type="email" name="email" class="form-control" required
                                placeholder="you@example.com">
                        </div>
                    </div>

                    <!-- End of TOP ROW: Shipping Address -->
                    <!-------------------------------------->


                    <!------------------------->
                    <!-- SECOND ROW: Payment -->
                    <div class="row g-3 mb-4">
                    <!--
                        - creates a new row
                        - g-3 = adds gap of 3 between columns
                        - mb-4 = adds a margin of size 4 below the row to separate it from the next section 
                    -->

                        <!-- col-md-4 will take up 1/3 of container width on screen-->
                        <div class="col-md-4">
                            <label for="payment">Payment Method:</label>
                            <!-- Dropdown menu using select-->
                            <select id="payment" name="payment">
                                <!-- The different payment options to choose, values used in javascript -->
                                <option value="credit-card">Credit Card</option>
                                <option value="paypal">Paypal</option>
                                <option value="stripe">Stripe</option>
                                <option value="crypto">Cryptocurrency</option>
                            </select>
                        </div>

                        <!----------------------------------------------------------->
                        <!-- Input Payment Details Containers (from custom module) -->

                        <!-- col-md-8 will take up 2/3 of container width on screen-->
                        <div class="col-md-8">
                            <!-- id used to load correct layout from custom module payment.js -->
                            <div id="credit-card-stripe-fields" class="payment-fields">
                                <%- creditCardFields %>
                            </div>

                            <!-- display none is used so that these are not initially shown when page loads-->
                             <!-- id used to load correct layout from custom module payment.js -->
                            <div id="paypal-fields" class="payment-fields" style="display: none;">
                                <%- paypalFields %>
                            </div>

                            <!-- id used to load correct layout from custom module payment.js -->
                            <div id="crypto-fields" class="payment-fields" style="display: none;">
                                <%- cryptoFields %>
                            </div>
                        </div>

                        <!-- End of Input Payment Details Containers (from custom module) -->
                        <!------------------------------------------------------------------>

                    </div>

                    <!-- End of SECOND ROW: Payment -->
                    <!-------------------------------->


            </div>
            <br>
            <hr>

            <!-- End of CHECKOUT SECTION -> PAYMENT, NAME, ADDRESS -->
            <!------------------------------------------------------->

            

            <!-------------------------------------->
            <!-- Total Cost & Bottom Row: Buttons -->
            <!--
                - creates a new row
                - align-items-center = vertically centres all content in the row
                - mb-4 = adds a margin of size 4 below the row to separate it from the next section 
            -->
            <div class="row align-items-center mb-4">
                <!--
                    - col = allows auto-size within the row
                    - d-flex align-items-center = will make the heading vertically centred 
                -->
                <div class="col d-flex align-items-center">
                    <!-- mb-0 = removes extra margin under the heading -->
                    <h3 class="mb-0">
                        <!-- id is used for Javascript to dynamically fill the total cost -->
                        Total Cost: <span id="checkout_total"></span>
                    </h3>
                </div>

                <!-- Buttons -->
                <!-- 
                    - col = allows auto-size within the row
                    - d-flex align-items-end = pushed the content to the right hand side
                    - align-items-center = ensures the buttons are vertically centred
                    - gap-2 = adds spacing between buttons of size 2
                -->
                <div class="col d-flex justify-content-end align-items-center gap-2">
                    <a href="/shop-all" class="mr-3">
                        <!-- button which brings user back to shopEntire page -->
                        <button type="button">Continue Shopping</button>
                    </a>

                    <!-- button which submits the form (if correctly filled out) to place the order -->
                    <!-- action at top of form redirects to the paymentSuccess page -->
                    <button id="placeOrderBtn" type="submit">Place Order</button>

                </div>
                <!-- End of Buttons -->
            </div>

            </form>
            <!-- End of Post Method form -->

        </div>
        <hr>

        <!-- End of Shopping Cart Section-->
        <!--------------------------------->


        <!------------------------>
        <!--Brand Logos Section -->

        <!--A band of brands across screen for logos of items being sold. Using class container to remove sliding bar 
        at bottom of screen and set the width of the images in the row-->
        <section class="container">
            <!--
            Row (bootstrap) to keep all images in one row, with img-fluid (bootstrap) to make the images responsive
            - col-lg-2 allows all six images in the row on a large screen
            - col-md-4 stacks them in two rows with three images per row on medium screen
            - col-6 puts two images per row on smaller sized screens, such as mobile
        -->
            <div class="row">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/nike-logo-black-and-white.png"
                    alt="nike">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/adidas-logo-black-and-white.png" alt="addidas">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/puma-logo-black-and-white.png"
                    alt="puma">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/umbro-logo-black-and-white.png" alt="umbro">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/Oneills-logo-black-and-white.png" alt="o'neills">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/macron-black-and-white.png"
                    alt="macron">
            </div>
        </section>

        <!--End of Brand Logos Section -->
        <!------------------------------->


        <!---------------------->
        <!--Back to Top Button-->
        <!-- id set for styling in CSS, function in Javascript-->
        <button id="backToTop" title="Go to top">↑ Top</button>

        <!--End of Back to Top Button-->
        <!----------------------------->



        <!------------------->
        <!-- Footer Section-->
        <%- include('templates/footer') %>

        <!-- End of Footer Section-->
        <!-------------------------->


        <!--Link JAVASCRIPT FILE-->
        <script src="/public/script.js"></script>


        <!--Importing Bootstrap 5 for JS-->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>


            <script>

                // Waits until all of the HTML document is loaded before running any JavaScript
                document.addEventListener("DOMContentLoaded", () => {

                    // Stores cost of all items in cart
                    let cost_allItems = 0;

                    // References to the cart display area and empty-cart message
                    let cartContainer = document.getElementById("cart_items");
                    let emptyMessage = document.getElementById("empty_cart");

                    // Checks if valid items exist in the cart
                    let hasItems = false;


                    // A loop to go through everything saved in local storage
                    for (let i = 0; i < localStorage.length; i++) {

                        // Gets the storage keys (from local storge)
                        let key = localStorage.key(i);
                        // Parse the stored JSON objects from the key
                        let content = JSON.parse(localStorage.getItem(key));

                        // Make sure the objects exist
                        // Make sure both price and quantity are type int
                        // Make sure size exists
                        if (
                            !content ||
                            typeof content.p !== "number" ||
                            typeof content.quan !== "number" ||
                            !content.s
                        ) {
                            // If all above are true then continue and skip any invalid entries
                            continue;
                        }

                        // Store the price and quantity as variables
                        // Store variables for the discount rate
                        let price = content.p;
                        let quantity = content.quan;
                        let discountRate = 0;
                        let discountSize = content.s;

                        //apply the discount logic based on size
                        if (discountSize === "Xtra Small") {
                            // 20% off for size Xtra Small
                            discountRate = 0.20;
                        } else if (discountSize === "Small") {
                            // 10% off for size Small
                            discountRate = 0.10;
                        }

                        //Calculate the discounted price by taking the discount amount from the original price
                        let discountedPrice = price * (1 - discountRate);
                        //Update the total cost for the items (price x quantity)
                        let total_cost = discountedPrice * content.quan;

                        // Only show items with a quantity greater than 0
                        if (content.quan > 0) {
                            hasItems = true;
                            cost_allItems += total_cost;

                            // Insert the cart items into HTML for the page
                            //output of the image, the key (product name and type), the quantity, the size, and the overall cost
                            //Apply a banner 'alert' of the discount only if a discount is applied - ${discountRate > 0 ?
                            //Then insert the image, name, size, quantity,
                            //price (with discount if applied and using <del> to strikthrough original)
                            //Sum the overall cost from the total row (toFixed(2)) ensures discounted prices are in this row
                            //Everything is wrapped in the div "cart-item-container" with data-key so I can remove items from cart
                            cartContainer.innerHTML += `
                        <div class="cart-item-container" data-key="${key}">
                            ${discountRate > 0 ? `
                                <div class="alert alert-warning w-100 mb-3">
                                    The <strong>${content.type}</strong> got a 
                                    <strong>${discountRate * 100}% discount</strong>
                                    from its original price of 
                                    <strong>€${price.toFixed(2)}</strong>
                                    because it is size <strong>${discountSize}</strong>.
                                </div>
                            ` : ""}

                            <div class="cart-item">
                            <div class="col-image"><img src="${content.img}" alt="${content.name}" /></div>
                            <div class="col-name"><a href="/shop?rec=${content.id}">${content.type}</a></div>
                            <div class="col-size">${content.s}</div>          
                            <div class="col-price">${discountRate > 0 ? `<del>€${price.toFixed(2)}</del><br>€${discountedPrice.toFixed(2)}`
                                    : `€${price.toFixed(2)}`
                                }
                                    </div>

                            <div class="col-quantity">${content.quan}</div>
                            <div class="col-total">€${total_cost.toFixed(2)}</div>
                            
                            <div class="col-cancel"><i class="fa-regular fa-circle-xmark"></i></div>
                        </div>
                    </div>
                
                 `;
                        }
                    }

                    //if loop to apply "No Items In Cart" message if no valid items exist in cart,  
                    //and apply it to the emptyMessage variable defined at top of script
                    if (!hasItems) {
                        emptyMessage.textContent = "No Items In Cart";
                    } else {
                        emptyMessage.textContent = "";
                    }


                    // Remove item from cart
                    // Done via click listeners
                    const cancelIcons = document.querySelectorAll(".col-cancel i");
                    cancelIcons.forEach(icon => {
                        icon.addEventListener("click", (e) => {
                            // Gets the key / data of the item in the row which was clicked
                            const container = e.target.closest(".cart-item-container");
                            const key = container.getAttribute("data-key");
                            localStorage.removeItem(key); // Remove the saved Item from Local Storage via its data-key
                            location.reload(); // Refresh the page to reload the cart display
                        });
                    });


                    // ---------------------
                    // Create the total cost
                    // ---------------------
                    const totalText = "€" + cost_allItems.toFixed(2);

                    // To get the price to show in both the cart
                    // and beneath the checkout part after the enter card details part
                    document.getElementById("final_price").textContent = "Total: " + totalText;
                    document.getElementById("checkout_total").textContent = totalText;
                    
                    // ----------------------------
                    // End of Create the total cost
                    // ----------------------------


                    // -------------------------------
                    // Login check before order submit
                    // -------------------------------
                    const placeOrderBtn = document.getElementById("placeOrderBtn");

                    // This variable comes from ejs res.locals.user (sessions)
                    const loggedInUser = "<%= user ? user : '' %>";

                    // If user is not logged in then the alert pops up and then cannot proceed via preventDefault
                    placeOrderBtn.addEventListener("click", (e) => {
                        if (!loggedInUser) {
                            e.preventDefault(); // Stop form submission
                            alert("Please Login before you can proceed");
                        }

                    });

                    // --------------------------------------
                    // End of Login check before order submit
                    // --------------------------------------


                    //--------------------------
                    // Payment switching options
                    //--------------------------
                    const paymentSelect = document.getElementById("payment");
                    const creditCardStripeFields = document.getElementById("credit-card-stripe-fields");
                    const paypalFields = document.getElementById("paypal-fields");
                    const cryptoFields = document.getElementById("crypto-fields");

                    // Show only the payment field which is selected 
                    // from the custom node module payment.ejs
                    function showPaymentFields(method) {
                        creditCardStripeFields.style.display = "none";
                        paypalFields.style.display = "none";
                        cryptoFields.style.display = "none";

                        if (method === "credit-card" || method === "stripe") {
                            creditCardStripeFields.style.display = "block";
                        } else if (method === "paypal") {
                            paypalFields.style.display = "block";
                        } else if (method === "crypto") {
                            cryptoFields.style.display = "block";
                        }
                    }

                    // Show correct form on page load
                    showPaymentFields(paymentSelect.value);

                    // Change form when user selects a different payment method
                    paymentSelect.addEventListener("change", (e) => {
                        showPaymentFields(e.target.value);
                    });

                    //--------------------------------
                    //End of Payment switching options
                    //--------------------------------


                });


            </script>


</body>

</html>