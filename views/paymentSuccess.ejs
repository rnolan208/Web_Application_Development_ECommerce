<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <title>Order Success</title>

    <!--Importing Bootstrap 5 for CSS-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!--Linking CSS file-->
    <link rel="stylesheet" href="/public/css/style.css">

    <!--Font Awesome-->
    <script src="https://kit.fontawesome.com/8875caf3cf.js" crossorigin="anonymous"></script>


</head>

<body>


    <!-------------------->
    <!-- Receipt Section-->
    <!-- id of receipt so CSS makes sure only this section prints-->
    <div id="receipt">
        <h1>Robert's Football Shop</h1>
        <p><strong>Order Receipt</strong></p>

        <!-- The order number is brought in from app.js (randomly generated with math random)-->
        <p>Order Number: <strong><%= orderNumber %></strong></p>
        <h3>Paymentment Successful</h3>
        <p>Thank you for your purchase! Here is your receipt:</p>

        <!-- Creates a table class to store the data for the receipt 
            - table = bootstrap table class
            - table-bordered = applies a border to the cells in the table 
        -->
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Size</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <!-- id receipt_items for use in Javascript -->
            <tbody id="receipt_items"></tbody>
        </table>

        <!-- For the total price -->
        <h3 class="text-right">

            <!-- id receipt_total for use in Javascript -->
            Total: <span id="receipt_total"></span>
        </h3>
    </div>

    <!-- End of Receipt Section-->
    <!--------------------------->


    <!--------------------------------------------->
    <!-- Buttons to Print Receipt or Back to Home
        - the window.print prints the entire screen (handled in CSS) 
        - btn-secondary = bootstrap which gives the colour grey to the button
        - onclick="window.print()" = inline JavaScript event
    -->
    <button class="btn btn-secondary" onclick="window.print()">Print Receipt</button>

    <!-- This button leads back to the home page -->
    <a href="/" class="btn btn-primary">Back to Home</a>

    <!-- End of Buttons to Print Receipt or Back to Home-->
    <!---------------------------------------------------->


    <!--Importing Bootstrap 5 for JS-->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>


    <script>

        // Waits until all of the HTML document is loaded before running any JavaScript
        document.addEventListener("DOMContentLoaded", () => {

            // References to the table body and total display elements
            const receiptContainer = document.getElementById("receipt_items");  // Receipt rows
            const totalElement = document.getElementById("receipt_total");      // Total cost

            // Total cost variable
            let cost_allItems = 0;

            // A loop to go through everything saved in local storage
            for (let i = 0; i < localStorage.length; i++) {

                // Gets the storage keys (from local storge)
                let key = localStorage.key(i);

                // Parse the stored JSON objects from the key
                let item = JSON.parse(localStorage.getItem(key));

                // Make sure the objects exist
                // Make sure both price and quantity are type int
                // Make sure size exists
                if (
                    !item ||
                    typeof item.p !== "number" ||
                    typeof item.quan !== "number" ||
                    !item.s
                ) {

                // If all above are true then continue and skip any invalid entries
                continue;
                }

                // Store the price and quantity as variables
                // Store variables for the discount rate
                const price = item.p;
                const quantity = item.quan;
                const discountSize = item.s;
                let discountRate = 0;


                if (discountSize === "Xtra Small") {
                    // 20% off for size Xtra Small
                     discountRate = 0.20;
                } else if (discountSize === "Small") {
                    // 10% off for size Small
                    discountRate = 0.10;
                }

                // Calculate discounted price and total for this item
                const discountedPrice = price * (1 - discountRate);
                const total_cost = discountedPrice * quantity;

                // Add to total cost
                cost_allItems += total_cost;

                // Adds a row to the receipt table for each item and values stored as table data
                receiptContainer.innerHTML += `
            <tr>
                <td>${item.type}</td>
                <td>${item.s}</td>
                <td>${item.quan}</td>
                <td>€${price.toFixed(2)}</td>
                <td>€${total_cost.toFixed(2)}</td>
            </tr>
        `;
            }

            // Show the total cost
            totalElement.textContent = "€" + cost_allItems.toFixed(2);

            // Clear the cart after receipt loads
            localStorage.clear();

        });

    </script>


</body>


</html>