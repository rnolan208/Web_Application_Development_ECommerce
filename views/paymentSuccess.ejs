<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <title>Order Success</title>

    <!--Importing Bootstrap for CSS-->
    <!--<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">-->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.1.3/dist/css/bootstrap.min.css"
        integrity="sha384-MCw98/SFnGE8fJT3GXwEOngsV7Zt27NXFoaoApmYm81iuXoPkFOJwJ8ERdknLPMO" crossorigin="anonymous">
    <!--Linking CSS file-->
    <link rel="stylesheet" href="/public/css/style.css">

    <!--Font Awesome-->
    <script src="https://kit.fontawesome.com/8875caf3cf.js" crossorigin="anonymous"></script>


</head>

<body>


    <!-------------------->
    <!-- Receipt Section-->
    <!-- id of receipt so CSS makes sure only this section prints-->
    <div id="receipt">
        <h1>Robert's Football Shop</h1>
        <p><strong>Order Receipt</strong></p>

        <!-- The order number is brought in from app.js (randomly generated with math random)-->
        <p>Order Number: <strong><%= orderNumber %></strong></p>
        <h3>Paymentment Successful</h3>
        <p>Thank you for your purchase! Here is your receipt:</p>

        <!-- Creates a table to store the data for the receipt -->
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Size</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody id="receipt_items"></tbody>
        </table>

        <!-- For the total price -->
        <h3 class="text-right">
            Total: <span id="receipt_total"></span>
        </h3>
    </div>

    <!-- End of Receipt Section-->
    <!--------------------------->

    <!--------------------------------------------->
    <!-- Buttons to Print Receipt or Back to Home-->
    <!-- the window.print prints the entire screen (handled in CSS) -->
    <button class="btn btn-secondary" onclick="window.print()">Print Receipt</button>

    <!-- This button leads back to the home page -->
    <a href="/" class="btn btn-primary">Back to Home</a>

    <!-- End of Buttons to Print Receipt or Back to Home-->
    <!---------------------------------------------------->


    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const receiptContainer = document.getElementById("receipt_items");
            const totalElement = document.getElementById("receipt_total");

            let total = 0;

            for (let i = 0; i < localStorage.length; i++) {
                const key = localStorage.key(i);
                const item = JSON.parse(localStorage.getItem(key));

                if (
                    !item ||
                    typeof item.p !== "number" ||
                    typeof item.quan !== "number" ||
                    !item.s
                ) continue;

                let discountRate = 0;
                if (item.s === "Xtra Small") discountRate = 0.20;
                else if (item.s === "Small") discountRate = 0.10;

                const price = item.p * (1 - discountRate);
                const subtotal = price * item.quan;
                total += subtotal;

                receiptContainer.innerHTML += `
            <tr>
                <td>${item.type}</td>
                <td>${item.s}</td>
                <td>${item.quan}</td>
                <td>€${price.toFixed(2)}</td>
                <td>€${subtotal.toFixed(2)}</td>
            </tr>
        `;
            }

            totalElement.textContent = "€" + total.toFixed(2);

            // Clear the cart after receipt loads
            localStorage.clear();

        });

    </script>


</body>


</html>