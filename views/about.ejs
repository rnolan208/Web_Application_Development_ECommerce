<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <!--Page Title-->
    <title>Robert's Sports Shop - About</title>

    <!--Importing Bootstrap 5 for CSS-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!--Linking CSS file-->
    <link rel="stylesheet" href="/public/css/style.css">

    <!--Font Awesome-->
    <script src="https://kit.fontawesome.com/8875caf3cf.js" crossorigin="anonymous"></script>

</head>

<body>

    <!-------------------->
    <!-- Navbar Section -->
    <%- include('templates/navbar') %>

        <!-- End of Navbar Section -->
        <!--------------------------->


        <!--------------------------->
        <!--Main Page Body Section -->

        <section id="home">
            <div class="container">
                <h1 class="aboutTitle">ABOUT</h1>
                <br>
                <div class="row justify-content-center">
                    <div class="col-md-5 d-flex flex-column align-items-center text-center">
                        <!--Left side - Project and Shop information-->
                        <div class="aboutUS">
                            <h4>Welcome to <strong>Robert’s Football Shop</strong>, your first stop for football
                                merchandise
                                from top football leagues.</h4>
                            <br>
                            <h5>Robert’s Football Shop is an e-commerce store created as part of the Web Applications
                                Development module within the
                                Software Development H. Dip. at ATU 2025/26.</h5>
                            <h5>The website was designed to showcase the core features and functionality of
                                a modern online retail platform. The store specialises in football apparel and
                                equipment,
                                with a strong focus on quality,
                                variety, and ease of use.</h5>
                            <h5>My aim is to provide a smooth and enjoyable shopping experience, from browsing products
                                to
                                completing secure online purchases,
                                while applying real-world HTML, CSS, JavaScipt, and NODE principles learned through
                                academic
                                study.</h5>

                        </div>
                    </div>
                    <div class="col-md-2 d-flex flex-column align-items-center text-center"></div>
                    <!--Right side - outline of what the site sells-->
                    <div class="col-md-5 d-flex flex-column align-items-center text-center">
                        <div class="aboutUS">
                            <h4>We offer a wide selection of soccer jerseys from top competitions, including:</h4>
                            <br>
                            <h5>
                                <ul class="list-unstyled">
                                    <li>Premier League</li>
                                    <li>League of Ireland</li>
                                    <li>La Liga</li>
                                    <li>Serie A</li>
                                    <li>Bundesliga</li>
                                    <li>Ligue 1</li>
                                    <li>International Teams</li>
                                </ul>
                            </h5>
                            <br>
                            <h5>In addition to jerseys, Robert’s Football Shop also stocks a range of football
                                essentials,
                                such as footballs, goalkeeper
                                gloves, soccer goals, and shin guards.</h5>
                            <br>
                            <h5>Thank you for visiting <strong>Robert’s Football Shop</strong> and supporting this
                                project.
                            </h5>
                        </div>
                    </div>
                </div>
        </section>

        <!-- End of Main Page Body Section -->
        <!----------------------------------->


        <!------------------------>
        <!--Brand Logos Section -->

        <!--A band of brands across screen for logos of items being sold. Using class container to remove sliding bar 
        at bottom of screen and set the width of the images in the row-->
        <section class="container">
            <!--
            Row (bootstrap) to keep all images in one row, with img-fluid (bootstrap) to make the images responsive
            - col-lg-2 allows all six images in the row on a large screen
            - col-md-4 stacks them in two rows with three images per row on medium screen
            - col-6 puts two images per row on smaller sized screens, such as mobile
        -->
            <div class="row">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/nike-logo-black-and-white.png"
                    alt="nike">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/adidas-logo-black-and-white.png" alt="addidas">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/puma-logo-black-and-white.png"
                    alt="puma">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/umbro-logo-black-and-white.png" alt="umbro">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/Oneills-logo-black-and-white.png" alt="o'neills">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/macron-black-and-white.png"
                    alt="macron">
            </div>
        </section>

        <!--End of Brand Logos Section -->
        <!------------------------------->


        <!---------------------->
        <!--Back to Top Button-->
        <!-- id set for styling in CSS, function in Javascript-->
        <button id="backToTop" title="Go to top">↑ Top</button>

        <!--End of Back to Top Button-->
        <!----------------------------->



        <!------------------->
        <!-- Footer Section-->
        <%- include('templates/footer') %>

            <!-- End of Footer Section-->
            <!-------------------------->


            <!--Link JAVASCRIPT FILE-->
            <script src="/public/script.js"></script>


            <!--Importing Bootstrap 5 for JS-->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>