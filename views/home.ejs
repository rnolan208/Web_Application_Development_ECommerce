                    </a>
                </div>
                <!--Right side - Image Carousel which picks Random Image from folder (using )-->
                <div class="col-md-7">
                    <div class="car">
                        <div class="img-wrap">
                            <% images.forEach((img, index)=> { %>
                                <img src="/public/images/jerseys/<%= img %>"
