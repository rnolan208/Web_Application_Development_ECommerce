        </a>
        <a href="/shop-all#goals">
            <button class="my-button">GOALS</button>
        </a>
        <a href="/shop-all#gloves">
            <button class="my-button">GOALKEEPER GLOVES</button>
        </a>
        <a href="/shop-all#shinPads">
            <button class="my-button">SHIN PADS</button>
        </a>
