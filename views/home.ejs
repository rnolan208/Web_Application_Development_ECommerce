<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <title>Robert's Sports Shop</title>

    <!--Importing Bootstrap for CSS-->
    <!--<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">-->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.1.3/dist/css/bootstrap.min.css"
        integrity="sha384-MCw98/SFnGE8fJT3GXwEOngsV7Zt27NXFoaoApmYm81iuXoPkFOJwJ8ERdknLPMO" crossorigin="anonymous">
    <!--Linking CSS file-->
    <link rel="stylesheet" href="/public/css/style.css">

    <!--Font Awesome-->
    <script src="https://kit.fontawesome.com/8875caf3cf.js" crossorigin="anonymous"></script>

</head>

<body>
    <!-------------------->
    <!-- Navbar Section -->
    <%- include('templates/navbar') %>

    <!-- End of Navbar Section -->
    <!--------------------------->


    <!--Main page body - link to shop and carousel of randomised images via JavaScript-->
    <section id="home">
        <div class="container">
            <div class="row">
                <div class="col-md-5 d-flex flex-column align-items-center text-center">
                    <!--Left side - Text and Button to Shop-->
                    <h5>Latest Arrivals</h5>
                    <h1>Best Prices</h1>
                    <p><em>Score Your Next Victory</em></p>
                    <a href="/shop-all">
                        <button>Shop Now</button>
                    </a>
                </div>
                <!--Right side - Image Carousel which picks Random Image from folder-->
                <div class="col-md-7">
                    <div class="car">
                        <div class="img-wrap">
                            <% images.forEach((img, index)=> { %>
                                <img src="/public/images/jerseys/<%= img %>"
                                    class="carousel-img <%= index === 0 ? 'active' : '' %>" alt="Product image">
                                <% }) %>
                        </div>
                        <!--Buttons to click next or previous image from the Carousel-->
                        <button class="btn prev">‹</button>
                        <button class="btn next">›</button>
                    </div>
                </div>
            </div>
    </section>

    <!--Slogan-->
    <section id="slogan">
        <div class="row">
            <img class="img-fluid" src="public/images/banner/banner.png" alt="slogan">
        </div>
    </section>

    <!--Featured Section-->
    <!--making 2 rows with a responsive image in each (bootstrap) and link to the store section-->
    <section id="feat_items" class="w-100">
        <div class="row p-0 m-0">
            <div class="one col-lg-6 col-md-12 col-12 p-0">
                <img class="img-fluid" src="public/images/featured_sections/Jerseys.jpg" alt="Jerseys">
                <!--title and button to store section-->
                <div class="details">
                    <h2>Jerseys</h2>
                    <a href="/jerseyShop">
                        <button class="text-uppercase">Shop Now</button>
                    </a>
                </div>
            </div>
            <div class="one col-lg-6 col-md-12 col-12 p-0">
                <img class="img-fluid" src="public/images/featured_sections/misc.jpg" alt="Miscellaneous">
                <!--title and button to store section-->
                <div class="details">
                    <h2>Miscellaneous</h2>
                    <a href="/miscShop">
                        <button class="text-uppercase">Shop Now</button>
                    </a>
                </div>
            </div>
        </div>
    </section>


<!------------------------>
        <!--Brand Logos Section -->

        <!--A band of brands across screen for logos of items being sold. Using class container to remove sliding bar 
        at bottom of screen and set the width of the images in the row-->
        <section class="container">
            <!--
            Row (bootstrap) to keep all images in one row, with img-fluid (bootstrap) to make the images responsive
            - col-lg-2 allows all six images in the row on a large screen
            - col-md-4 stacks them in two rows with three images per row on medium screen
            - col-6 puts two images per row on smaller sized screens, such as mobile
        -->
            <div class="row">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/nike-logo-black-and-white.png"
                    alt="nike">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/adidas-logo-black-and-white.png" alt="addidas">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/puma-logo-black-and-white.png"
                    alt="puma">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/umbro-logo-black-and-white.png" alt="umbro">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/Oneills-logo-black-and-white.png" alt="o'neills">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/macron-black-and-white.png"
                    alt="macron">
            </div>
        </section>

        <!--End of Brand Logos Section -->
        <!------------------------------->


        <!---------------------->
        <!--Back to Top Button-->
        <!-- id set for styling in CSS, function in Javascript-->
        <button id="backToTop" title="Go to top">↑ Top</button>

        <!--End of Back to Top Button-->
        <!----------------------------->


        <!------------------->
        <!-- Footer Section-->
        <%- include('templates/footer') %>

        <!-- End of Footer Section-->
        <!-------------------------->


        <!--Link JAVASCRIPT FILE-->
        <script src="/public/script.js"></script>



    <!--Importing Bootstrap for JS and Popper-->
    <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.14.3/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.1.3/dist/js/bootstrap.min.js"></script>


</body>


</html>


<script>
    const images = document.querySelectorAll(".carousel-img");
    const prevBtn = document.querySelector(".prev");
    const nextBtn = document.querySelector(".next");

    let currentIndex = 0;

    function showImage(index) {
        images.forEach(img => img.classList.remove("active"));
        images[index].classList.add("active");
    }

    nextBtn.addEventListener("click", () => {
        currentIndex = (currentIndex + 1) % images.length;
        showImage(currentIndex);
    });

    prevBtn.addEventListener("click", () => {
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        showImage(currentIndex);
    });

    // Auto-play
    setInterval(() => {
        currentIndex = (currentIndex + 1) % images.length;
        showImage(currentIndex);
    }, 4000);
</script>