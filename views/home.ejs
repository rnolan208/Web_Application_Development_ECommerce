                    <p>Roberts Footall Shop &copy 2026. All Rights Reserved</p>
                </div>
                <!--Social Media Icons from Font Awesome with links(no links included for this project)-->
                <div class="col-lg-4 col-md-6 col-12">
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#"><i class="fa-brands fa-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-linkedin-in"></i></i></a>
                </div>
            </div>
        </div>

    </footer>



    <!--Importing Bootstrap for JS and Popper-->
    <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.14.3/dist/umd/popper.min.js"></script>
