        </a>
        <a href="/shop-all#laLiga">
            <button class="my-button">LA LIGA</button>
        </a>
        <a href="/shop-all#leagueOfIreland">
            <button class="my-button">LEAGUE OF IRELAND</button>
        </a>
        <a href="/shop-all#serieA">
            <button class="my-button">SERIE A</button>
        </a>
