<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <title>Robert's Sports Shop</title>

    <!--Importing Bootstrap 5 for CSS-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!--Linking CSS file-->
    <link rel="stylesheet" href="/public/css/style.css">

    <!--Font Awesome-->
    <script src="https://kit.fontawesome.com/8875caf3cf.js" crossorigin="anonymous"></script>

</head>

<body>
    <!-------------------->
    <!-- Navbar Section -->
    <%- include('templates/navbar') %>

    <!-- End of Navbar Section -->
    <!--------------------------->


    <!------------------------------------------------>
    <!-- Main Page Top - links to shop and carousel -->

    <!-- 
        - id of home used to apply background image from CSS 
        - bootstrap container 
        - row to create horizontal flex container for Bootstrap columns
    -->
    <section id="home">
        <div class="container">
            <div class="row">
                <!--Left Side Column - Text and Button to Shop-->
                <!--
                    - col-md-5 = spans 5/12 of the row on medium and large screens
                    - d-flex = makes a flexbox
                    - flex-column = stacks the items vertically
                    - align-items-center = aligns items in the middle on the horizontal axis
                    - justify-content-center = aligns items in the middle on the vertical axis
                    - text-center = makes all text be central in the column
                -->
                <div class="col-md-5 d-flex flex-column align-items-center justify-content-center text-center">
                    <h5>Latest Arrivals</h5>
                    <h1>Best Prices</h1>
                    <p><em>Score Your Next Victory</em></p>
                    <a href="/shop-all">
                        <button>Shop Now</button>
                    </a>
                </div>
                <!-- End of Left Side Column - Text and Button to Shop -->


                <!-- Right side - Image Carousel -->
                <!--
                    - class car for CSS - button and image positions
                    - col-md-7 = spans 7/12 of the row on medium and large screens
                    - class img-wrap = set the height, width, and position in CSS
                    - forEach loop to display saved images from array (app.js)
                -->
                <div class="col-md-7">
                    <div class="car">
                        <div class="img-wrap">
                            <% images.forEach((img, index)=> { %>
                                <img src="/public/images/jerseys/<%= img %>"
                                    class="carousel-img <%= index === 0 ? 'active' : '' %>" alt="Product image">
                                <% }) %>
                        </div>
                        <!--Buttons to click next or previous image from the Carousel-->
                        <!--
                            - class btn prev = show previous image, used via Javascript
                            - class btn next = show next image, used via Javascript
                        -->
                        <button class="btn prev">‹</button>
                        <button class="btn next">›</button>
                    </div>
                </div>
                <!-- End of Right side - Image Carousel-->

            </div>
            <!-- End of Row -->

        </div>
        <!-- End of Container -->

    </section>
    <!-- End of Main Page Top -->
    <!-------------------------->


    <!-------------------->
    <!-- Slogan Section -->
    <!-- id of slogan used for CSS to set display, colour, text alignment-->
    <section id="slogan">
        <!--
            - bootstrap container
            - row to create horizontal flex container for Bootstrap columns
            - img fluid for responsive image
        -->
        <div class="container">
            <div class="row">
                <img class="img-fluid" src="public/images/banner/banner.png" alt="slogan">
            </div>
        </div>
    </section>
    <!-- End of Slogan Section -->
    <!--------------------------->


    <!---------------------->
    <!-- Featured Section -->

    <!-- Two large responsive feature tiles with full-width image, title, and shop now button-->
    <!-- 
        - id feat_items for CSS styling
        - class="w-100" = makes element 100% wide (images)
    -->
    <section id="feat_items" class="w-100">

        <!-- bootstrap row with no padding or margin-->
        <div class="row p-0 m-0">
            <!-- 
                - Left Side Column (Jerseys)
                - .one is used for custom styling and positioning in CSS
                - col-lg-6 = half width on large screens
                - col-md-12 / col-12 = full width on medium and small screens
                - p-0 removes inner spacing so the image fills the column
                - img-fluid = responsive image (bootstrap)
            -->
            <div class="one col-lg-6 col-md-12 col-12 p-0">
                <img class="img-fluid" src="public/images/featured_sections/Jerseys.jpg" alt="Jerseys">
                <!-- Title and button - class details for CSS styling -->
                <div class="details">
                    <br>

                    <!-- Category title displayed over the image -->
                    <h1><strong>Jerseys</strong></h1>

                    <!-- Link to the Jerseys shop page -->
                    <a href="/jerseyShop">
                        <button class="text-uppercase">Shop Now</button>
                    </a>
                </div>
                <!-- End of Title and button -->

            </div>
            <!-- End of Left Side Column -->

            <!-- Right Side Column (Misc) -->
            <!-- Same structure and layout as Left Side Column -->
            <div class="one col-lg-6 col-md-12 col-12 p-0">
                <img class="img-fluid" src="public/images/featured_sections/misc.jpg" alt="Miscellaneous">
                <!-- Title and button - class details for CSS styling -->
                <div class="details">
                    <br>

                    <!-- Category title displayed over the image -->
                    <h1><strong>Miscellaneous</strong></h1>

                    <!-- Link to the Misc Items shop page -->
                    <a href="/miscShop">
                        <button class="text-uppercase">Shop Now</button>
                    </a>
                </div>
                <!-- End of Title and button -->
                 
            </div>
            <!-- End of Right Side Column -->

        </div>
        <!-- End of Row -->

    </section>
    <!-- End of Featured Section -->
    <!----------------------------->


        <!------------------------>
        <!--Brand Logos Section -->

        <!--A band of brands across screen for logos of items being sold. Using class container to remove sliding bar 
        at bottom of screen and set the width of the images in the row-->
        <section class="container">
            <!--
            Row (bootstrap) to keep all images in one row, with img-fluid (bootstrap) to make the images responsive
            - col-lg-2 allows all six images in the row on a large screen
            - col-md-4 stacks them in two rows with three images per row on medium screen
            - col-6 puts two images per row on smaller sized screens, such as mobile
        -->
            <div class="row">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/nike-logo-black-and-white.png"
                    alt="nike">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/adidas-logo-black-and-white.png" alt="addidas">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/puma-logo-black-and-white.png"
                    alt="puma">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/umbro-logo-black-and-white.png" alt="umbro">
                <img class="img-fluid col-lg-2 col-md-4 col-6"
                    src="/public/images/brands/Oneills-logo-black-and-white.png" alt="o'neills">
                <img class="img-fluid col-lg-2 col-md-4 col-6" src="/public/images/brands/macron-black-and-white.png"
                    alt="macron">
            </div>
        </section>

        <!--End of Brand Logos Section -->
        <!------------------------------->


        <!---------------------->
        <!--Back to Top Button-->
        <!-- id set for styling in CSS, function in Javascript-->
        <button id="backToTop" title="Go to top">↑ Top</button>

        <!--End of Back to Top Button-->
        <!----------------------------->


        <!------------------->
        <!-- Footer Section-->
        <%- include('templates/footer') %>

        <!-- End of Footer Section-->
        <!-------------------------->


        <!--Link JAVASCRIPT FILE-->
        <script src="/public/script.js"></script>



        <!--Importing Bootstrap 5 for JS-->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>





<script>

    // Select all images used in the carousel
    const images = document.querySelectorAll(".carousel-img");

    // Select the buttons for previous and next for the carousel
    const prevBtn = document.querySelector(".prev");
    const nextBtn = document.querySelector(".next");

    // Tracks images used in carousel array, starting at index 0
    let currentIndex = 0;


    // Function to show images at specific index
    function showImage(index) {

        // Hides all images by removing the active class
        images.forEach(img => img.classList.remove("active"));

        // Only adds active to the selected images
        images[index].classList.add("active");
    }

    // For the clicking of the next button
    nextBtn.addEventListener("click", () => {

        // Moves to next image and modulo makes index wrap back to 0 at end of array
        currentIndex = (currentIndex + 1) % images.length;

        // Displays the next image
        showImage(currentIndex);
    });

    // For the previous of the next button
    prevBtn.addEventListener("click", () => {

        // Moves to previous image and modulo makes index wrap back to 0 at end of array
        // Adding images.length stops negative numbers
        currentIndex = (currentIndex - 1 + images.length) % images.length;

        // Displays the previous image
        showImage(currentIndex);
    });

    // Auto-play
    // Every 3 seconds the carousle automatically moves to the next image in the array
    setInterval(() => {
        currentIndex = (currentIndex + 1) % images.length;
        showImage(currentIndex);
    }, 3000);
</script>

</body>


</html>